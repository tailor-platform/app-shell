// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Tooltip > snapshots > closed tooltip (trigger only) 1`] = `"<button type="button" id="base-ui-_r_1_" data-slot="tooltip-trigger">Hover me</button>"`;

exports[`Tooltip > snapshots > open tooltip 1`] = `"<div><button type="button" id="base-ui-_r_3_" data-slot="tooltip-trigger" data-testid="trigger" data-popup-open="">Hover me</button></div><div id="_r_4_" data-base-ui-portal="" style="position: relative; z-index: 50;"><div data-open="" data-side="top" data-align="center" role="presentation" style="position: absolute; left: 0px; top: 0px; transition: none; transform: translate(-5px, -5px); --available-width: -10px; --available-height: -11px; --anchor-width: 0px; --anchor-height: 0px; --transform-origin: 1px calc(100% + 5px);" data-anchor-hidden=""><div data-open="" data-side="top" data-align="center" data-starting-style="" tabindex="-1" data-base-ui-focusable="" style="transition: none;" data-slot="tooltip-content" class="astw:bg-primary astw:text-primary-foreground astw:animate-in astw:fade-in-0 astw:zoom-in-95 astw:data-ending-style:animate-out astw:data-ending-style:fade-out-0 astw:data-ending-style:zoom-out-95 astw:data-[side=bottom]:slide-in-from-top-2 astw:data-[side=left]:slide-in-from-right-2 astw:data-[side=right]:slide-in-from-left-2 astw:data-[side=top]:slide-in-from-bottom-2 astw:z-50 astw:w-fit astw:overflow-visible astw:origin-(--transform-origin) astw:rounded-md astw:px-3 astw:py-1.5 astw:text-xs astw:text-balance">Helpful information<div data-open="" data-side="top" data-align="center" data-uncentered="" style="position: absolute; left: 1px;" aria-hidden="true" class="astw:size-2.5 astw:rotate-45 astw:bg-primary astw:data-[side=top]:-bottom-1 astw:data-[side=bottom]:-top-1 astw:data-[side=left]:-right-1 astw:data-[side=right]:-left-1"></div></div></div></div>"`;

exports[`Tooltip > snapshots > tooltip with provider 1`] = `"<button type="button" id="base-ui-_r_7_" data-slot="tooltip-trigger">Hover me</button>"`;
